{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A spare part for agricultural tractors",
      "type": "object",
      "properties": {
        "pieceNumber": { "type": "string", "description": "OEM or alternative part number" },
        "description": { "type": "string", "description": "Detailed description of the part" },
        "brand": { "type": "string", "description": "Tractor brand (MF, JD, NH, etc.)" },
        "model": { "type": "string", "description": "Compatible tractor model" },
        "purchasePrice": { "type": "number", "description": "Cost of the product" },
        "salePrice": { "type": "number", "description": "Selling price" },
        "stock": { "type": "integer", "description": "Current inventory level" },
        "minStock": { "type": "integer", "description": "Minimum stock alert level" },
        "maxStock": { "type": "integer", "description": "Maximum stock level" },
        "location": { "type": "string", "description": "Warehouse location (aisle, shelf, box)" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "barcode": { "type": "string", "description": "Scannable barcode or QR code" },
        "vendorId": { "type": "string", "description": "ID of the primary vendor" },
        "leadTime": { "type": "integer", "description": "Days to restock" },
        "category": { "type": "string", "description": "Part category (Motor, Transmission, etc.)" }
      },
      "required": ["pieceNumber", "description", "brand", "salePrice", "stock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A completed transaction",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "ID of the customer" },
        "items": { "type": "array", "description": "Items sold" },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["EFECTIVO", "TARJETA", "TRANSFERENCIA", "CRÉDITO"] },
        "status": { "type": "string", "enum": ["COMPLETED", "CANCELLED", "QUOTATION"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "sellerId": { "type": "string" }
      },
      "required": ["items", "total", "paymentMethod", "status", "timestamp"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["FISICA", "MORAL"] },
        "rfc": { "type": "string" },
        "curp": { "type": "string" },
        "address": { "type": "object" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "creditLimit": { "type": "number" },
        "creditDays": { "type": "integer" },
        "discount": { "type": "number" },
        "priceList": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVO", "INACTIVO", "MOROSO"] },
        "balance": { "type": "number" }
      },
      "required": ["name", "rfc", "status"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "Supplier profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["NACIONAL", "INTERNACIONAL"] },
        "rfc": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "contact": { "type": "string" },
        "leadTime": { "type": "integer" },
        "rating": { "type": "integer" }
      },
      "required": ["name"]
    },
    "BusinessConfig": {
      "title": "BusinessConfig",
      "description": "White-label configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "rfc": { "type": "string" },
        "address": { "type": "string" },
        "terms": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "App user and role",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "VENDEDOR", "ALMACENISTA", "GERENTE", "CAJERO"] },
        "branchId": { "type": "string" }
      },
      "required": ["name", "email", "role"]
    },
    "InventoryMovement": {
      "title": "InventoryMovement",
      "description": "Stock change history",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "type": { "type": "string", "enum": ["IN", "OUT", "ADJ"] },
        "quantity": { "type": "number" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["productId", "type", "quantity", "timestamp", "userId"]
    },
    "Employee": {
      "title": "Employee",
      "description": "HR and Payroll data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "rfc": { "type": "string" },
        "curp": { "type": "string" },
        "role": { "type": "string" },
        "position": { "type": "string" },
        "hireDate": { "type": "string", "format": "date" },
        "salary": { "type": "number" },
        "commissionRate": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "bankAccount": { "type": "string" },
        "taxRegime": { "type": "string" },
        "zipCode": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "name", "rfc", "status"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily check-in/out",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "checkIn": { "type": "string", "format": "date-time" },
        "checkOut": { "type": "string", "format": "date-time" },
        "location": { "type": "object" },
        "status": { "type": "string", "enum": ["PRESENT", "ABSENT", "LATE", "VACATION"] }
      },
      "required": ["employeeId", "date", "checkIn"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "CFDI 4.0 Electronic Invoice",
      "type": "object",
      "properties": {
        "folio": { "type": "string" },
        "series": { "type": "string" },
        "uuid": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "taxAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["VIGENTE", "CANCELADO", "PENDIENTE"] },
        "pacResponse": { "type": "object" },
        "xmlUrl": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "customerId": { "type": "string" },
        "saleId": { "type": "string" },
        "usage": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentForm": { "type": "string" }
      },
      "required": ["folio", "total", "status", "customerId", "saleId"]
    },
    "SatConfig": {
      "title": "SatConfig",
      "description": "SAT Credentials and PAC settings",
      "type": "object",
      "properties": {
        "encryptedCSD": { "type": "string" },
        "encryptedKey": { "type": "string" },
        "businessRFC": { "type": "string" },
        "businessName": { "type": "string" },
        "pacApiKeys": { "type": "string" },
        "taxRegime": { "type": "string" },
        "address": { "type": "string" },
        "zipCode": { "type": "string" }
      }
    },
    "Commission": {
      "title": "Commission",
      "description": "Monthly commission calculation",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "period": { "type": "string" },
        "totalSales": { "type": "number" },
        "calculatedCommission": { "type": "number" },
        "status": { "type": "string", "enum": ["PAID", "PENDING"] },
        "salesIds": { "type": "array" }
      },
      "required": ["employeeId", "period", "calculatedCommission", "status"]
    },
    "VirtualAssistant": {
      "title": "VirtualAssistant",
      "description": "Configuration for a specialized virtual assistant",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "color": { "type": "string" },
        "specialty": { "type": "string", "enum": ["pos", "inventory", "finance", "hr", "fiscal", "general"] },
        "greeting": { "type": "string" },
        "tone": { "type": "string", "enum": ["formal", "friendly", "technical", "direct"] },
        "enabled": { "type": "boolean" },
        "isDefault": { "type": "boolean" },
        "autonomyLevel": { "type": "integer" },
        "contextMemory": { "type": "boolean" },
        "sessionDuration": { "type": "integer" },
        "language": { "type": "string" },
        "allowedRoles": { "type": "array" },
        "enabledFunctions": { "type": "array" },
        "restrictedActions": { "type": "array" },
        "quickCommands": { "type": "array" },
        "notifications": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "specialty", "enabled"]
    },
    "AssistantConversation": {
      "title": "AssistantConversation",
      "description": "Chat history with a virtual assistant",
      "type": "object",
      "properties": {
        "assistantId": { "type": "string" },
        "userId": { "type": "string" },
        "messages": { "type": "array" },
        "context": { "type": "object" },
        "startedAt": { "type": "string", "format": "date-time" },
        "lastActivity": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["assistantId", "userId", "messages", "startedAt"]
    },
    "AssistantSettings": {
      "title": "AssistantSettings",
      "description": "Global settings for the multi-assistant system",
      "type": "object",
      "properties": {
        "autoSwitchByContext": { "type": "boolean" },
        "defaultAssistantId": { "type": "string" },
        "maxConcurrentAssistants": { "type": "integer" },
        "allowCustomAssistants": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Spare parts catalog" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales records" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer database" },
    "/vendors/{vendorId}": { "schema": "Vendor", "description": "Supplier database" },
    "/businessConfig/main": { "schema": "BusinessConfig", "description": "App branding and settings" },
    "/users/{userId}": { "schema": "User", "description": "User profiles and roles" },
    "/inventoryMovements/{movementId}": { "schema": "InventoryMovement", "description": "History of stock changes" },
    "/employees/{employeeId}": { "schema": "Employee", "description": "HR records" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance logs" },
    "/invoices/{invoiceId}": { "schema": "Invoice", "description": "Tax invoices" },
    "/satConfig/main": { "schema": "SatConfig", "description": "SAT configuration" },
    "/commissions/{commissionId}": { "schema": "Commission", "description": "Commission reports" },
    "/virtual_assistants/{assistantId}": { "schema": "VirtualAssistant", "description": "Virtual assistants configuration" },
    "/assistant_conversations/{conversationId}": { "schema": "AssistantConversation", "description": "Chat histories" },
    "/assistant_settings/global": { "schema": "AssistantSettings", "description": "Global assistant settings" }
  }
}
